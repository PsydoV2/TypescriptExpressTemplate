{
  "name": "express-ts-backend-template",
  "version": "3.0.0",
  "description": "A generic backend template using Express and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && npm run copy-templates",
    "copy-templates": "copyfiles -u 1 src/templates/**/* dist/",
    "start": "node dist/index.js",
    "start:local": "npm run build && cross-env NODE_ENV=development node dist/index.js",
    "start:test": "npm run build && cross-env NODE_ENV=test node dist/index.js",
    "start:prod": "npm run build && cross-env NODE_ENV=production node dist/index.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watchAll --detectOpenHandles"
  },
  "author": "Your Name",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.5",
    "nodemailer": "^9.0.3",
    "rate-limiter-flexible": "^11.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
